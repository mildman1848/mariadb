# Copy to .env for local MariaDB image development.
# Never commit .env or generated secrets.

IMAGE_NAME=mariadb
APP_VERSION=11.8.8
IMAGE_REVISION=mldm2
REGISTRY=ghcr.io/mildman1848
PLATFORMS=linux/amd64,linux/arm64
LOAD_PLATFORM=linux/amd64
CONTAINER_NAME=mariadb-dev
MYSQL_DATABASE=app
MYSQL_USER=mariadb
TZ=Europe/Berlin
PUID=1000
PGID=1000
